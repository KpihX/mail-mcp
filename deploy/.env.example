# mail-mcp Docker deployment — secrets injected as env vars
# Copy to deploy/.env, fill values, NEVER commit .env to git

# Account credentials (mapped from config.yaml username_env / password_env)
X_LOGIN=your_imap_username
X_PASS=your_imap_password

# HTTP transport settings (optional — defaults shown)
MAIL_MCP_HTTP_HOST=0.0.0.0
MAIL_MCP_HTTP_PORT=8094
MAIL_MCP_HTTP_MCP_PATH=/mcp
MAIL_MCP_PUBLIC_BASE_URL=https://mail.kpihx-labs.com
MAIL_MCP_FALLBACK_BASE_URL=https://mail.homelab

# Admin env file path — persistent credential overrides (Docker volume mount)
# Allows updating credentials via mail-admin without redeploying
MAIL_MCP_ADMIN_ENV_FILE=/data/mail-admin.env
